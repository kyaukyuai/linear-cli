export const snapshot = {};

snapshot[`Capabilities Command - Help Text 1`] = `
stdout:
"
Usage: capabilities

Description:

  Describe the agent-facing command surface

Options:

  -h, --help  - Show this help.                           
  -j, --json  - Output the capabilities registry as JSON  

Examples:

  Describe agent-facing capabilities as JSON linear capabilities --json                                               
  Find commands that support dry-run         linear capabilities --json | jq '.commands[] | select(.dryRun.supported)'

"
stderr:
""
`;

snapshot[`Capabilities Command - Human Summary 1`] = `
stdout:
"linear-cli 2.10.0
capabilities schema: v1
automation contract latest: v4
dry-run preview contract: v1
stdin policy: v1

automation tier
  v1: linear issue children, linear issue comment add, linear issue create, linear issue create-batch, linear issue list, linear issue parent, linear issue relation add, linear issue relation delete, linear issue relation list, linear issue update, linear issue view, linear team members
  v2: linear cycle current, linear cycle list, linear cycle next, linear cycle view, linear milestone list, linear milestone view, linear project list, linear project view
  v3: linear document list, linear document view, linear notification count, linear notification list, linear webhook list, linear webhook view

agent-facing commands
  linear api :: json=no dry-run=no stdin=implicit_text confirm=none idempotency=read_only
    note: Outputs JSON by default and accepts stdin, but does not use a --json flag.
  linear capabilities :: json=yes dry-run=no stdin=none confirm=none idempotency=read_only
  linear cycle current :: json=v2 dry-run=no stdin=none confirm=none idempotency=read_only
  linear cycle list :: json=v2 dry-run=no stdin=none confirm=none idempotency=read_only
  linear cycle next :: json=v2 dry-run=no stdin=none confirm=none idempotency=read_only
  linear cycle view :: json=v2 dry-run=no stdin=none confirm=none idempotency=read_only
  linear document create :: json=no dry-run=v1 stdin=implicit_text confirm=none idempotency=non_idempotent
  linear document delete :: json=no dry-run=v1 stdin=explicit_bulk confirm=--yes idempotency=destructive
  linear document list :: json=v3 dry-run=no stdin=none confirm=none idempotency=read_only
  linear document update :: json=no dry-run=v1 stdin=implicit_text confirm=none idempotency=retry_safe_update
  linear document view :: json=v3 dry-run=no stdin=none confirm=none idempotency=read_only
  linear issue children :: json=v1 dry-run=no stdin=none confirm=none idempotency=read_only
  linear issue comment add :: json=v1 dry-run=v1 stdin=implicit_text confirm=none idempotency=non_idempotent
  linear issue comment update :: json=no dry-run=no stdin=implicit_text confirm=none idempotency=retry_safe_update
  linear issue create :: json=v1 dry-run=v1 stdin=implicit_text confirm=none idempotency=non_idempotent
  linear issue create-batch :: json=v1 dry-run=v1 stdin=none confirm=none idempotency=resumable_batch
    retry: Partial failures return createdIdentifiers and failedStep details.
  linear issue list :: json=v1 dry-run=no stdin=none confirm=none idempotency=read_only
  linear issue parent :: json=v1 dry-run=no stdin=none confirm=none idempotency=read_only
  linear issue relation add :: json=v1 dry-run=v1 stdin=none confirm=none idempotency=retry_safe_no_op
    retry: Adding an existing relation succeeds with noOp: true.
  linear issue relation delete :: json=v1 dry-run=v1 stdin=none confirm=none idempotency=retry_safe_no_op
    retry: Deleting a missing relation succeeds with noOp: true.
  linear issue relation list :: json=v1 dry-run=no stdin=none confirm=none idempotency=read_only
  linear issue start :: json=no dry-run=v1 stdin=none confirm=none idempotency=conditional
    retry: The dry-run is safe to repeat; the live path mutates both Linear state and local VCS state.
  linear issue update :: json=v1 dry-run=v1 stdin=implicit_text confirm=none idempotency=conditional
    retry: Field-only updates are retry-safe; adding --comment makes the command non-idempotent.
  linear issue view :: json=v1 dry-run=no stdin=none confirm=none idempotency=read_only
  linear label list :: json=v4 dry-run=no stdin=none confirm=none idempotency=read_only
  linear milestone create :: json=no dry-run=v1 stdin=none confirm=none idempotency=non_idempotent
  linear milestone delete :: json=no dry-run=v1 stdin=none confirm=--yes idempotency=destructive
  linear milestone list :: json=v2 dry-run=no stdin=none confirm=none idempotency=read_only
  linear milestone update :: json=no dry-run=v1 stdin=none confirm=none idempotency=retry_safe_update
  linear milestone view :: json=v2 dry-run=no stdin=none confirm=none idempotency=read_only
  linear notification archive :: json=yes dry-run=no stdin=none confirm=none idempotency=retry_safe_no_op
    retry: Archiving an already-archived notification succeeds with noOp: true.
  linear notification count :: json=v3 dry-run=no stdin=none confirm=none idempotency=read_only
  linear notification list :: json=v3 dry-run=no stdin=none confirm=none idempotency=read_only
  linear notification read :: json=yes dry-run=no stdin=none confirm=none idempotency=retry_safe_no_op
    retry: Reading an already-read notification succeeds with noOp: true.
  linear project create :: json=yes dry-run=v1 stdin=none confirm=none idempotency=non_idempotent
  linear project delete :: json=no dry-run=v1 stdin=none confirm=--yes idempotency=destructive
  linear project label add :: json=yes dry-run=no stdin=none confirm=none idempotency=retry_safe_no_op
    retry: Adding an already-attached label succeeds with changed: false.
  linear project label remove :: json=yes dry-run=no stdin=none confirm=none idempotency=retry_safe_no_op
    retry: Removing a missing label succeeds with changed: false.
  linear project list :: json=v2 dry-run=no stdin=none confirm=none idempotency=read_only
  linear project update :: json=no dry-run=v1 stdin=none confirm=none idempotency=retry_safe_update
  linear project view :: json=v2 dry-run=no stdin=none confirm=none idempotency=read_only
  linear project-label list :: json=v4 dry-run=no stdin=none confirm=none idempotency=read_only
  linear team list :: json=v4 dry-run=no stdin=none confirm=none idempotency=read_only
  linear team members :: json=v1 dry-run=no stdin=none confirm=none idempotency=read_only
  linear team view :: json=v4 dry-run=no stdin=none confirm=none idempotency=read_only
  linear user list :: json=v4 dry-run=no stdin=none confirm=none idempotency=read_only
  linear user view :: json=v4 dry-run=no stdin=none confirm=none idempotency=read_only
  linear webhook create :: json=yes dry-run=v1 stdin=none confirm=none idempotency=non_idempotent
  linear webhook delete :: json=yes dry-run=v1 stdin=none confirm=--yes idempotency=destructive
  linear webhook list :: json=v3 dry-run=no stdin=none confirm=none idempotency=read_only
  linear webhook update :: json=yes dry-run=v1 stdin=none confirm=none idempotency=retry_safe_update
  linear webhook view :: json=v3 dry-run=no stdin=none confirm=none idempotency=read_only
  linear workflow-state list :: json=v4 dry-run=no stdin=none confirm=none idempotency=read_only
  linear workflow-state view :: json=v4 dry-run=no stdin=none confirm=none idempotency=read_only
"
stderr:
""
