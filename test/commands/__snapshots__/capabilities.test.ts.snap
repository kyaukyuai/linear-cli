            "source": "argument",
            "name": "issue",
            "description": "Defaults to the current issue from the branch name or jj trailer.",
            "value": null
          },
          {
            "source": "flag",
            "name": "--timeout-ms",
            "description": "Falls back to LINEAR_WRITE_TIMEOUT_MS or the built-in timeout.",
            "value": null
          }
        ],
        "resolutions": [
          {
            "source": "argument",
            "name": "issue",
            "strategy": "current_issue_context",
            "description": "If omitted, the CLI resolves the current issue from the branch name or jj trailer.",
            "sources": [
              {
                "kind": "git_branch",
                "name": "issue identifier from branch name",
                "value": null
              },
              {
                "kind": "jj_trailer",
                "name": "linear issue trailer",
                "value": null
              }
            ]
          },
          {
            "source": "stdin",
            "name": "stdin",
            "strategy": "implicit_input_source",
            "description": "If no explicit description is provided, the CLI reads stdin before using interactive editor flow.",
            "sources": [
              {
                "kind": "stdin",
                "name": "implicit description text",
                "value": null
              }
            ]
          },
          {
            "source": "flag",
            "name": "--timeout-ms",
            "strategy": "env_or_internal_default",
            "description": "The timeout falls back to LINEAR_WRITE_TIMEOUT_MS or the built-in default when omitted.",
            "sources": [
              {
                "kind": "env",
                "name": "LINEAR_WRITE_TIMEOUT_MS",
                "value": null
              },
